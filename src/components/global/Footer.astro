---
import Logo from "@/components/assets/Logo.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const links = [
  { href: "https://www.linkedin.com/in/daikiokayama/", text: "LinkedIn" },
  { href: "https://github.com/okayama-daiki", text: "GitHub" },
];
const year = new Date().getFullYear();
---

<footer class="border-t border-base-100 dark:border-base-800">
  <Wrapper variant="standard" class="py-8">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="flex items-center gap-2 text-xs tracking-tight text-base-600 dark:text-base-300">
        <span>© {year}</span>
        <Logo />
      </div>
      <div class="flex flex-wrap items-center gap-8">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer" class="text-xs tracking-tight text-base-600 transition-colors hover:text-base-900 dark:text-base-300 dark:hover:text-white">
            {link.text}
          </a>
        ))}
      </div>
      <a href="/" class="text-xs tracking-tight text-base-600 lg:col-start-4 lg:ml-auto dark:text-base-300">
        Back to top
      </a>
    </div>
  </Wrapper>
</footer>
