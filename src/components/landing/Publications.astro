---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";
---

<section class="scroll-mt-24" id="publications">
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-4">
      <div class="lg:col-start-2">
        <Text tag="p" variant="textSM" class="text-base-600 dark:text-base-300">
          Peer-reviewed work<br />2026
        </Text>
      </div>
      <Text tag="h2" variant="textXL" class="font-semibold leading-snug tracking-tighter text-base-900 dark:text-white lg:col-span-2">
        Publications
      </Text>
    </div>

    <article class="mt-12 border-t border-base-200 py-12 dark:border-base-800">
      <div class="grid grid-cols-1 items-start gap-4 lg:grid-cols-4">
        <Text tag="p" variant="textXS" class="uppercase text-base-600 dark:text-base-300">SIROCCO 2026</Text>
        <Text tag="h3" variant="textLG" class="font-semibold leading-tight text-base-900 dark:text-white">
          Online Exploration of Grid Graphs with Multiple Searchers
        </Text>
        <div class="space-y-3">
          <Text tag="p" variant="textSM" class="text-base-600 dark:text-base-300">
            Yuya Higashikawa, Shuichi Miyazaki, and Daiki Okayama
          </Text>
          <Text tag="p" variant="textXS" class="text-base-600 dark:text-base-300">
            33rd International Colloquium on Structural Information and Communication Complexity, June 2026
          </Text>
        </div>
        <a
          href="https://doi.org/10.1007/978-3-032-26465-7_20"
          target="_blank"
          rel="noreferrer"
          aria-label="Open the publication DOI"
          class="text-base-900 transition-colors hover:text-accent-600 dark:text-white lg:ml-auto"
        >
          <ArrowRight class="size-4" />
        </a>
      </div>
    </article>
  </Wrapper>
</section>
