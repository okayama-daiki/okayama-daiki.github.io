---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const { frontmatter } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(frontmatter.date));
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  canonicalPath={Astro.url.pathname}
>
  <article>
    <Wrapper variant="standard" class="pb-24 pt-40 lg:pt-64">
      <header class="grid grid-cols-1 gap-8 border-b border-base-200 pb-12 dark:border-base-800 lg:grid-cols-4 lg:pb-20">
        <div class="lg:col-start-2">
          <p class="text-xs uppercase tracking-wide text-base-600 dark:text-base-300">{formattedDate}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {frontmatter.tags.map((tag: string) => (
              <span class="rounded-full bg-base-100 px-3 py-1 text-xs text-base-600 dark:bg-base-800 dark:text-base-300">{tag}</span>
            ))}
          </div>
        </div>
        <div class="lg:col-span-2">
          <h1 class="text-3xl font-semibold leading-tight tracking-tighter text-base-900 dark:text-white sm:text-4xl lg:text-5xl">
            {frontmatter.title}
          </h1>
        </div>
      </header>

      <div class="article-body prose prose-base mx-auto mt-12 max-w-3xl dark:prose-invert lg:mt-20">
        <slot />
      </div>
    </Wrapper>
  </article>
</BaseLayout>
